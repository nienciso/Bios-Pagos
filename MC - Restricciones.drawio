        <mxCell id="jdYBQBF6eHAeaqKGUMWJ-9" value="- La fecha de pago no puede ser anterior a la fecha de registro." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
