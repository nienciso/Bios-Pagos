        <mxCell id="jdYBQBF6eHAeaqKGUMWJ-3" value="- El numero de sucursal debe ser positivo." style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="910" y="850" width="310" height="30" as="geometry" />
        </mxCell>
        <mxCell id="jdYBQBF6eHAeaqKGUMWJ-4" value="- no puede haber dos sucursales con el mismo numero." style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="940" y="870" width="310" height="30" as="geometry" />
        </mxCell>
        <mxCell id="jdYBQBF6eHAeaqKGUMWJ-5" value="- Un usuraio no puede registrarse con un e-mail ya existente." style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
