        </mxCell>
        <mxCell id="jdYBQBF6eHAeaqKGUMWJ-6" value="-&amp;nbsp;El monto enviado debe ser mayor a 0." style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="900" y="890" width="310" height="30" as="geometry" />
        </mxCell>
        <mxCell id="jdYBQBF6eHAeaqKGUMWJ-7" value="-&amp;nbsp;Un envío no puede modificarse luego de ser cobrado." style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
